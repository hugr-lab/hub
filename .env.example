# =============================================================================
# Analytics Hub Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# --- Required ---

# Hugr server base URL (without /ipc)
HUGR_URL=http://hugr:15000

# OIDC client secret (Hub uses confidential client)
OIDC_CLIENT_SECRET=change-me

# Hub external URL (must match redirect URI registered in OIDC provider)
HUB_BASE_URL=http://localhost:8000

# Encryption key for JupyterHub auth_state storage
# Generate with: openssl rand -hex 32
JUPYTERHUB_CRYPT_KEY=

# --- Optional ---

# Override OIDC client_id (default: from Hugr /auth/config)
# OIDC_CLIENT_ID=hugr-hub

# Hugr management secret key (for local dev mode and future Hub Service)
# HUGR_SECRET_KEY=local-dev-secret

# Workspace container image
# SINGLEUSER_IMAGE=hugr-lab/hub-singleuser:latest

# Docker network name
# DOCKER_NETWORK=hub-network

# Managed connection name in workspace
# HUGR_CONNECTION_NAME=default

# --- TLS ---

# Skip TLS certificate verification for Hugr server (self-signed certs)
# HUGR_TLS_SKIP_VERIFY=false

# Skip TLS certificate verification for OIDC provider (separate from Hugr)
# OIDC_TLS_SKIP_VERIFY=false

# Hub TLS (direct HTTPS without reverse proxy)
# HUB_SSL_CERT=/path/to/cert.pem
# HUB_SSL_KEY=/path/to/key.pem

# --- OIDC Provider Overrides ---

# Username claim in userinfo/id_token (default: preferred_username)
# Entra ID: use "email" (preferred_username not available in id_token)
# OIDC_USERNAME_CLAIM=email

# Extract user info from id_token instead of calling userinfo endpoint
# Entra ID: required because userinfo endpoint needs Graph-scoped token
# OIDC_USERDATA_FROM_ID_TOKEN=1

# Extra OAuth scopes (comma-separated)
# Entra ID: custom API scope to get correct audience in access token
# OIDC_EXTRA_SCOPES=api://<client-id>/access

# --- Resource Profiles ---

# OIDC claim for Hub profile assignment (Keycloak: x-hub-profile, Entra: groups)
# HUGR_PROFILE_CLAIM=x-hub-profile

# OIDC claim for Hugr role (default: x-hugr-role)
# HUGR_ROLE_CLAIM=x-hugr-role

# OIDC claim + values for Hub admin detection
# HUGR_ADMIN_CLAIM=x-hugr-role
# HUGR_ADMIN_VALUES=admin

# Static admin usernames (comma-separated, fallback when no OIDC admin claim)
# HUGR_ADMIN_USERS=admin

# Path to profiles.json (default: /srv/jupyterhub/config/profiles.json)
# HUGR_PROFILES_PATH=/srv/jupyterhub/config/profiles.json

# Secret provider for ${secret:KEY} in profiles.json (env, k8s, vault)
# HUGR_SECRET_PROVIDER=env

# Spawner type (docker or kubernetes)
# HUGR_SPAWNER=docker

# --- Idle Culler ---

# Idle timeout in seconds (default: 3600 = 1 hour)
# HUGR_IDLE_TIMEOUT=3600

# Max server age in seconds (default: 86400 = 24 hours)
# HUGR_MAX_SERVER_AGE=86400

# Cull check interval in seconds (default: 300 = 5 minutes)
# HUGR_CULL_INTERVAL=300

# Warning time before cull in seconds (default: 300 = 5 minutes)
# HUGR_CULL_WARN_BEFORE=300

# Include admin servers in culling (default: false)
# HUGR_CULL_ADMINS=false

# --- Keycloak Example ---
# OIDC_CLIENT_ID=hugr-hub
# OIDC_ISSUER=http://keycloak:8080/realms/hugr

# --- Microsoft Entra ID Example ---
# OIDC_CLIENT_ID=<application-client-id>
# OIDC_USERNAME_CLAIM=email
# OIDC_USERDATA_FROM_ID_TOKEN=1
# OIDC_EXTRA_SCOPES=api://<application-client-id>/access
# See docs/entra-id-setup.md for full setup guide
