FROM golang:1.26-alpine AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY cmd/ cmd/
COPY pkg/ pkg/
RUN CGO_ENABLED=0 go build -o /hub-agent ./cmd/hub-agent/

FROM python:3.12-slim
RUN apt-get update && apt-get install -y --no-install-recommends bash curl && rm -rf /var/lib/apt/lists/*
COPY --from=builder /hub-agent /usr/local/bin/hub-agent

RUN mkdir -p /shared /.agent/skills
WORKDIR /.agent

ENTRYPOINT ["hub-agent"]
