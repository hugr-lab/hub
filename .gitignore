# Project docs (local only)
design/
.claude/
.specify/
specs/
.mem/

# Environment
.env
.entra.env
.tls.env
*.env.local
.env.test

# TLS certs (dev only)
certs/

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# The console SPA build output is managed by console/.gitignore +
# console/dist/.gitignore (which keeps the go:embed placeholder index.html);
# re-include it so the broad Python `dist/` rule above doesn't swallow it.
!console/dist/

# Node
node_modules/

# JupyterLab extension build artifacts
extensions/*/lib/
extensions/*/hub_*/labextension/
extensions/*/.yarn/
extensions/*/yarn.lock
extensions/*/.venv/

# Go
/hub-service
/hub-agent
/result-store-mcp
/kernel-mcp
bin/

# Docker
hub-data/
/hugr-data/
hub-db-data/
hub-storage/

# Helm (downloaded dependencies)
k8s/*/charts/
k8s/*/Chart.lock

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Work directory (user data, not tracked)
work/


# Local dev secrets (agent JWT signing key etc.)
.local/

# Delve / VS Code debug binaries
__debug_bin*

# Local shared/ runtime data (DuckDB dumps etc.); README.txt stays tracked
shared/
