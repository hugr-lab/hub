FROM golang:1.26-alpine AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY cmd/ cmd/
COPY pkg/ pkg/
RUN CGO_ENABLED=0 go build -o /hub-service ./cmd/hub-service/

FROM alpine:latest
RUN apk add --no-cache ca-certificates
COPY --from=builder /hub-service /usr/local/bin/hub-service

EXPOSE 8082 50051
ENTRYPOINT ["hub-service"]
